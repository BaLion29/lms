    "name": "xsd:string",
    "updated_at": "xsd:dateTime",
    "valid_from": {
      "@class": "xsd:dateTime",
      "@type": "Optional"
    },
    "valid_until": {
      "@class": "xsd:dateTime",
      "@type": "Optional"
    }
  },
  {
