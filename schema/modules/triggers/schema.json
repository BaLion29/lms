      "@type": "Optional"
    },
    "subject_class": {
      "@class": "xsd:string",
      "@type": "Optional"
    }
  },
  {
    "@id": "RelativeTrigger",
    "@inherits": "Trigger",
    "@type": "Class",
    "anchor": "Remindable",
