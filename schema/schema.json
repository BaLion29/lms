    {
        "@id": "InboxAudioStatus",
        "@type": "Enum",
        "@value": [
            "new",
            "transcribed",
            "processed",
            "failed",
            "archived"
        ]
    },
    {
        "@id": "TaskStatus",
        "@type": "Enum",
        "@value": [
            "open",
            "planned",
            "done"
        ]
    },
    {
        "@id": "EventStatus",
        "@type": "Enum",
        "@value": [
            "open",
            "planned",
            "closed",
            "cancelled"
        ]
    },
    {
        "@id": "InboxNoteStatus",
        "@type": "Enum",
        "@value": [
            "new",
            "processed",
            "failed",
            "archived"
        ]
    },
    {
        "@id": "CompositeMode",
        "@type": "Enum",
        "@value": [
            "and",
            "or",
            "not"
        ]
    },
    {
        "@id": "EventKind",
        "@type": "Enum",
        "@value": [
            "created",
            "updated",
            "completed",
            "status_changed"
        ]
