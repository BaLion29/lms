# Quick start: set the 4 required values below, then `docker compose up -d`.
# Generate the 3 secrets with:  openssl rand -hex 32
# ── Persistent TOML config (optional) ────────────────────────────────────────
# Path to an optional TOML config file that acts as a lower-precedence
# fallback for all 8 Firnline services.  Env vars *always* take precedence.
# See docs/reference/configuration.md for the table structure and precedence rules.
#FIRNLINE_CONFIG_FILE=/etc/firnline/config.toml

# ── Extensions ───────────────────────────────────────────────────────────────
# Comma-separated list of extensions to install into the shared overlay volume.
# The bootstrap container installs them (FIRNLINE_EXTENSIONS_INSTALL=true); all other
# services mount the overlay read-only.
#
# Supported specifier formats:
#   • PyPI name (with optional version):         firnline_ext_address_book>=0.1.0
#   • Git URL:                                   git+https://github.com/org/repo.git
#   • Wheel filename (resolved against /extensions/ in the image):
#     firnline_ext_address_book-0.1.0-py3-none-any.whl
#     First-party wheels are baked into the images at build time — no side
#     channel needed.  Wheel filenames must match the versions in
#     extensions/<name>/pyproject.toml.
#
# First-party extensions built from extensions/:
FIRNLINE_EXTENSIONS=firnline_ext_address_book-0.1.0-py3-none-any.whl,firnline_ext_time_management-0.1.0-py3-none-any.whl
FIRNLINE_EXTENSIONS_PURGE=false

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# TerminusDB admin password (generate with: openssl rand -hex 32)
TDB_PASSWORD=
# API bearer token for the capture service (generate with: openssl rand -hex 32)
CAPTURED_API_TOKEN=
# API bearer token for the queryd service (generate with: openssl rand -hex 32)
QUERYD_API_TOKEN=
# OpenAI-compatible LLM endpoint (LiteLLM proxy or similar)
#   Host LLM via host-gateway:     http://host.docker.internal:4000
#     (compose.yaml already maps host.docker.internal → host-gateway; works on Linux too.)
#   Or use the commented litellm service in compose.yaml:  http://litellm:4000
FIRNLINE_LLM_BASE_URL=http://host.docker.internal:4000

# ── Optional TerminusDB ───────────────────────────────────────────────────────
# The bundled TerminusDB service (in compose.yaml) is the default.  To use your
# own TerminusDB instance:
#   1. Delete or comment out the `terminusdb` service block and the
#      `terminusdb_data` volume in compose.yaml.
#   2. Uncomment and set TDB_URL below to point to your instance.
# TDB_URL=http://your-terminusdb:6363
TDB_ORG=admin
TDB_DB=firnline
TDB_USER=admin
TDB_BRANCH=main
TDB_HOST_PORT=6363

# ── LLM model ─────────────────────────────────────────────────────────────────
FIRNLINE_LLM_API_KEY=
FIRNLINE_LLM_MODEL=gpt-4.1-mini

# ── Ops ───────────────────────────────────────────────────────────────────────
# Gates the /v1/tools REST surface (write-tool specs) — consumed by mcpd.
QUERYD_ENABLE_WRITES=false

# mcpd registers queryd write tools as dynamic MCP tools at startup.
#MCPD_ENABLE_QUERYD_TOOLS=true
# Within apid, cross-component calls default to http://localhost:8080.
# Override for non-standard setups:
#MCPD_QUERYD_URL=http://localhost:8080
#MCPD_CAPTURED_URL=http://localhost:8080
#QUERYD_INDEXED_URL=http://localhost:8080
#APID_LOG_LEVEL=INFO
#CAPTURED_LOG_LEVEL=INFO
#QUERYD_LOG_LEVEL=INFO
#INDEXED_LOG_LEVEL=INFO
#INGESTD_LOG_LEVEL=INFO
#TRIGGERD_LOG_LEVEL=INFO
#EFFECTD_LOG_LEVEL=INFO
#MCPD_LOG_LEVEL=INFO
APID_HOST_PORT=8080
INGESTD_POLL_INTERVAL_SECONDS=60
INGESTD_MAX_LLM_RETRIES=3
INGESTD_DRY_RUN=false

# ── indexed ───────────────────────────────────────────────────────────────────
#INDEXED_API_TOKEN=
#INGESTD_INDEXED_URL=http://apid:8080
#INDEXED_LOG_LEVEL=INFO
#INDEXED_POLL_INTERVAL_SECONDS=60
#INDEXED_DRY_RUN=false
#INDEXED_STRICT_PLUGINS=false
#INDEXED_MIN_CONFIDENCE=0.60
#INDEXED_LIVENESS_FILE=/tmp/indexed-alive
#FIRNLINE_EMBEDDING_MODEL=text-embedding-3-small
#INGESTD_INDEXED_ENABLED=false
#INGESTD_INDEXED_MIN_CONFIDENCE=0.85
#QUERYD_INDEXED_ENABLED=false
#QUERYD_INDEXED_MIN_CONFIDENCE=0.60

# ── WebUI ─────────────────────────────────────────────────────────────────────
WEBUI_HOST_PORT=3000
# Optional UI password gate; empty disables login.
WEBUI_PASSWORD=
# WebUI frontend needs an absolute URL pointing to the webui container.
# Default http://localhost:3000 works for localhost access; change for remote.
WEBUI_API_URL=http://localhost:3000
# Optional token for indexed healthz auth; falls back to INDEXED_API_TOKEN when unset.
#WEBUI_INDEXED_API_TOKEN=
# MCPD healthz URL — mounted at /mcp on apid (default http://apid:8080/mcp)
#WEBUI_MCPD_URL=http://apid:8080/mcp

# ── Geocoding (address-book / effectd) ────────────────────────────────────────
# Nominatim-compatible service used by effectd + queryd geocode tool.
#GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
#GEOCODING_API_KEY=
#GEOCODING_TIMEOUT_SECONDS=10.0
#GEOCODING_USER_AGENT=firnline-address-book

# ── effectd ───────────────────────────────────────────────────────────────────
#EFFECTD_POLL_INTERVAL_SECONDS=30
#EFFECTD_LIVENESS_FILE=/tmp/effectd-alive
#EFFECTD_DRY_RUN=false
#EFFECTD_LEGACY_NOTIFICATION_LOOP=true
#EFFECTD_DEFAULT_NOTIFY_EXECUTOR=notify:gotify
#EFFECTD_PLANNING_LOOKBACK=P7D
#EFFECTD_MAX_EXECUTIONS_PER_CYCLE=50
#EFFECTD_DEFAULT_MAX_ATTEMPTS=3
#EFFECTD_DEFAULT_RETRY_BACKOFF=PT1M
#EFFECTD_DEFAULT_TIMEOUT=PT30S
#EFFECTD_STRICT_PLUGINS=false

# ── triggerd ──────────────────────────────────────────────────────────────────
#TRIGGERD_POLL_INTERVAL_SECONDS=60
#TRIGGERD_LOOKBACK_SECONDS=900
#TRIGGERD_DEFAULT_TIMEZONE=UTC
#TRIGGERD_DRY_RUN=false
#TRIGGERD_STRICT_PLUGINS=false
#TRIGGERD_LIVENESS_FILE=/tmp/triggerd-alive
#INGESTD_LIVENESS_FILE=/tmp/ingestd-alive

# ── Proxy / forwarded headers ──────────────────────────────────────────────────
# When firnline is behind a reverse proxy (Traefik, nginx, Caddy, etc.),
# enable proxy_headers and set the CIDR(s) of the trusted proxy.
# Each service has its own prefixed variable (e.g. APID_PROXY_HEADERS,
# CAPTURED_FORWARDED_ALLOW_IPS) because the fields are inherited from
# FirnlineBaseSettings via each service's env prefix.
#
# Defaults (when unset):
#   PROXY_HEADERS=false         — uvicorn ignores X-Forwarded-* headers
#   FORWARDED_ALLOW_IPS=127.0.0.1 — only trust localhost forwards
#   TRUSTED_HOSTS=<empty>        — no Host header validation (uses Starlette
#                                  TrustedHostMiddleware; currently only apid
#                                  reads APID_TRUSTED_HOSTS)
#
# When behind Traefik (compose.traefik.yaml), apid's forwarded_allow_ips
# can be set to * because apid's ports are un-published.
#APID_PROXY_HEADERS=false
#APID_FORWARDED_ALLOW_IPS=127.0.0.1
#APID_TRUSTED_HOSTS=

# ── Traefik deployment ─────────────────────────────────────────────────────────
# Required when using compose.traefik.yaml.  DOMAIN must be a real,
# publicly-resolvable domain name for Let's Encrypt TLS certificates.
# localhost or internal Docker hostnames will NOT get a valid certificate.
#DOMAIN=
#ACME_EMAIL=
#
# When behind the proxy, set the browser-facing URLs:
#   WEBUI_API_URL=https://your-domain
#   REFLEX_API_URL=https://your-domain
#
# To un-publish TerminusDB (make it internal-only), set TDB_HOST_PORT empty:
#TDB_HOST_PORT=

# ── Consumer compose (compose.example.yaml) ───────────────────────────────────
# These variables are used ONLY by compose.example.yaml (pre-built images).
# They are NOT needed when using the developer compose.yaml.

# Docker Hub namespace/org for the firnline images.
#FIRNLINE_IMAGE_REGISTRY=firnline

# Image tag to pull. Set to a specific version to pin (e.g. 0.1.0-alpha).
#FIRNLINE_VERSION=latest
