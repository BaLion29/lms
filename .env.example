# ── Extensions ───────────────────────────────────────────────────────────────
# Comma-separated list of extensions to install into the shared overlay volume.
# The bootstrap container installs them (LMS_EXTENSIONS_INSTALL=true); all other
# services mount the overlay read-only.
#
# Supported specifier formats:
#   • PyPI name (with optional version):         lms_ext_inbox>=0.1.0
#   • Git URL:                                   git+https://github.com/org/repo.git
#   • Wheel filename (resolved against /extensions/ in the image):
#     lms_ext_inbox-0.1.0a1-py3-none-any.whl
#     First-party wheels are baked into the images at build time — no side
#     channel needed.  Wheel filenames must match the versions in
#     extensions/<name>/pyproject.toml.
#
# First-party extensions built from extensions/:
LMS_EXTENSIONS=lms_ext_inbox-0.1.0a1-py3-none-any.whl,lms_ext_people-0.1.0a1-py3-none-any.whl,lms_ext_planning-0.1.0a1-py3-none-any.whl,lms_ext_reminders-0.1.0a1-py3-none-any.whl
LMS_EXTENSIONS_PURGE=false

# ── TerminusDB ───────────────────────────────────────────────────────────────
# REQUIRED — generate e.g. with: openssl rand -hex 32
TDB_PASSWORD=
TDB_ORG=admin
TDB_DB=lms
TDB_USER=admin
TDB_BRANCH=main
TDB_HOST_PORT=6363
# REQUIRED — TerminusDB base URL (e.g. http://10.0.10.20:6364).
# For the self-contained bundled stack, set: TDB_URL=http://terminusdb:6363
TDB_URL=

# ── LLM (external LiteLLM proxy — NOT run by this compose) ──────────────────
LMS_LLM_BASE_URL=http://host.docker.internal:4000
LMS_LLM_API_KEY=
LMS_LLM_MODEL=gpt-4.1-mini

# ── Service auth tokens ─────────────────────────────────────────────────────
# REQUIRED — generate e.g. with: openssl rand -hex 32
CAPTURED_API_TOKEN=
QUERYD_API_TOKEN=

# ── Ops ─────────────────────────────────────────────────────────────────────
QUERYD_ENABLE_WRITES=false
CAPTURED_HOST_PORT=8088
QUERYD_HOST_PORT=8087
INGESTD_POLL_INTERVAL_SECONDS=60
INGESTD_MAX_LLM_RETRIES=3
INGESTD_DRY_RUN=false
