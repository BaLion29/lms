[
  {
    "@id": "Task",
    "@inherits": [
      "Remindable",
      "Source",
      "TaskSpec"
    ],
    "@type": "Class",
    "created_at": "xsd:dateTime",
    "derived_from": {
      "@class": "Source",
      "@type": "Optional"
    },
    "due_date": {
      "@class": "xsd:dateTime",
      "@type": "Optional"
    },
    "status": "TaskStatus",
    "updated_at": "xsd:dateTime"
  },
  {
    "@id": "Event",
    "@inherits": [
      "Remindable",
      "Source",
      "Context"
    ],
    "@type": "Class",
    "created_at": "xsd:dateTime",
    "derived_from": {
      "@class": "Source",
      "@type": "Optional"
    },
    "description": {
      "@class": "xsd:string",
      "@type": "Optional"
    },
    "end_datetime": {
      "@class": "xsd:dateTime",
      "@type": "Optional"
    },
    "estimated_duration": {
      "@class": "xsd:integer",
      "@type": "Optional"
    },
    "location": {
      "@class": "Location",
      "@type": "Optional"
    },
    "name": "xsd:string",
    "priority": {
      "@class": "xsd:integer",
      "@type": "Optional"
    },
    "start_datetime": {
      "@class": "xsd:dateTime",
      "@type": "Optional"
    },
    "status": "EventStatus",
    "updated_at": "xsd:dateTime"
  },
  {
    "@id": "TaskSpec",
    "@type": "Class",
    "description": {
      "@class": "xsd:string",
      "@type": "Optional"
    },
    "estimated_duration": {
      "@class": "xsd:integer",
      "@type": "Optional"
    },
    "name": "xsd:string",
    "priority": {
      "@class": "xsd:integer",
      "@type": "Optional"
    },
    "required_context": {
      "@class": "Context",
      "@type": "Set"
    }
  },
  {
    "@id": "TaskStatus",
    "@type": "Enum",
    "@value": [
      "open",
      "planned",
      "done"
    ]
  },
  {
    "@id": "EventStatus",
    "@type": "Enum",
    "@value": [
      "open",
      "planned",
      "closed",
      "cancelled"
    ]
  }
]
