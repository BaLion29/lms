[
  {"@id": "Task", "@inherits": ["Entity", "Remindable", "Source", "Anchored", "TaskSpec"], "@type": "Class",
   "@metadata": {
     "label_field": "name",
     "anchor_field": "due_date",
     "transitions": {
       "open": ["planned", "done"],
       "planned": ["open", "done"],
       "done": ["open"]
     }
   },
   "@documentation": {"@comment": "A todo item with a due date and status. Derives from a source, can be reminded, and has a canonical anchor instant."},
   "due_date": {"@class": "xsd:dateTime", "@type": "Optional"},
   "status": "TaskStatus"},
  {"@id": "Event", "@inherits": ["Entity", "Remindable", "Source", "Context", "Anchored"], "@type": "Class",
   "@metadata": {
     "label_field": "name",
     "anchor_field": "start_datetime",
     "transitions": {
       "open": ["planned", "closed", "cancelled"],
       "planned": ["open", "closed", "cancelled"],
       "closed": ["open"],
       "cancelled": ["open"]
     }
   },
   "@documentation": {"@comment": "A calendar event with start/end datetimes, location, priority, and status. Can be a context for other documents."},
   "description": {"@class": "xsd:string", "@type": "Optional"},
   "end_datetime": {"@class": "xsd:dateTime", "@type": "Optional"},
   "estimated_duration": {"@class": "xsd:integer", "@type": "Optional"},
   "location": {"@class": "Location", "@type": "Optional"},
   "name": "xsd:string",
   "priority": {"@class": "xsd:integer", "@type": "Optional"},
   "start_datetime": {"@class": "xsd:dateTime", "@type": "Optional"},
   "status": "EventStatus"},
  {"@id": "TaskSpec", "@type": "Class",
   "@documentation": {"@comment": "Shared fields for task-like documents: name, description, estimated duration, priority, and required context."},
   "description": {"@class": "xsd:string", "@type": "Optional"},
   "estimated_duration": {"@class": "xsd:integer", "@type": "Optional"},
   "name": "xsd:string",
   "priority": {"@class": "xsd:integer", "@type": "Optional"},
   "required_context": {"@class": "Context", "@type": "Set"}},
  {"@id": "TaskStatus", "@type": "Enum",
   "@documentation": {"@comment": "Task lifecycle: open, planned, or done."},
   "@value": ["open", "planned", "done"]},
  {"@id": "EventStatus", "@type": "Enum",
   "@documentation": {"@comment": "Event lifecycle: open, planned, closed, or cancelled."},
   "@value": ["open", "planned", "closed", "cancelled"]},
  {"@id": "Routine", "@inherits": ["Entity", "Source", "Remindable", "Triggerable"], "@type": "Class",
   "@metadata": {"label_field": "name"},
   "@documentation": {"@comment": "A named, repeating routine composed of ordered steps. Can be reminded and triggered."},
   "name": "xsd:string",
   "required_context": {"@class": "Context", "@type": "Set"},
   "steps": {"@class": "RoutineStep", "@type": "List"}},
  {"@id": "RoutineStep", "@inherits": ["Entity", "Source"], "@type": "Class",
   "@metadata": {"label_field": "name"},
   "@oneOf": {"activity": "ActivitySpec", "task": "TaskSpec"},
   "@documentation": {"@comment": "A single step in a routine, referencing either an ActivitySpec or TaskSpec with an optional cadence in days."},
   "cadence_days": {"@class": "xsd:integer", "@type": "Optional"},
   "name": "xsd:string"},
  {"@id": "Activity", "@inherits": ["Entity", "Remindable", "Source", "Context", "Anchored", "ActivitySpec"], "@type": "Class",
   "@metadata": {"label_field": "name", "anchor_field": "start_datetime"},
   "@documentation": {"@comment": "A concrete instance of an activity from a routine, with scheduled start/end datetimes."},
   "end_datetime": {"@class": "xsd:dateTime", "@type": "Optional"},
   "routine": {"@class": "Routine", "@type": "Optional"},
   "start_datetime": {"@class": "xsd:dateTime", "@type": "Optional"}},
  {"@id": "ActivitySpec", "@type": "Class",
   "@documentation": {"@comment": "Shared template for activity-like documents: name, description, estimated duration, and priority."},
   "description": {"@class": "xsd:string", "@type": "Optional"},
   "estimated_duration": {"@class": "xsd:integer", "@type": "Optional"},
   "name": "xsd:string",
   "priority": {"@class": "xsd:integer", "@type": "Optional"}}
]
