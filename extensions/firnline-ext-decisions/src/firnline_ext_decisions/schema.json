[
  {"@id": "Decision", "@type": "Class", "@inherits": ["Entity", "Source"],
   "@metadata": {"label_field": "title",
     "transitions": {
       "draft": ["proposed", "rejected"],
       "proposed": ["accepted", "rejected", "draft"],
       "accepted": ["superseded", "deprecated"],
       "rejected": ["draft"]
     }},
   "@documentation": {"@comment": "An ADR-style decision record: context, the decision made, its consequences, considered alternatives, and lifecycle status."},
   "title": "xsd:string",
   "context": {"@class": "xsd:string", "@type": "Optional"},
   "decision": "xsd:string",
   "consequences": {"@class": "xsd:string", "@type": "Optional"},
   "status": "DecisionStatus",
   "options": {"@class": "ConsideredOption", "@type": "List"},
   "supersedes": {"@class": "Decision", "@type": "Optional"}},
  {"@id": "ConsideredOption", "@type": "Class", "@subdocument": [], "@key": {"@type": "Random"},
   "@documentation": {"@comment": "An alternative that was considered for a Decision."},
   "name": "xsd:string",
   "pros": {"@class": "xsd:string", "@type": "Set"},
   "cons": {"@class": "xsd:string", "@type": "Set"},
   "rejection_reason": {"@class": "xsd:string", "@type": "Optional"}},
  {"@id": "DecisionStatus", "@type": "Enum",
   "@documentation": {"@comment": "Lifecycle status of an ADR-style decision record."},
   "@value": ["draft", "proposed", "accepted", "rejected", "superseded", "deprecated"]}
]
